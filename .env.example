# Docker compose picks this up automatically — single source of truth for all services
# Copy to .env and fill in your values: cp .env.example .env
# Generate new keys per deployment: python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=generate-a-real-64-char-hex-string
ENCRYPTION_KEY=generate-a-real-64-char-hex-string
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Default user passwords for initial seed (Alembic migration)
ADMIN_PASSWORD=change-me-admin
ACCOUNTANT_PASSWORD=change-me-accountant
AUDITOR_PASSWORD=change-me-auditor
