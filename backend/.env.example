# ── Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# WARNING: .env contains secrets — NEVER commit .env to version control!
#
# ENVIRONMENT: "development" | "production"
#   - development: cookies secure=False, SQLite OK, debug-friendly
#   - production:  cookies secure=True (requires HTTPS), PostgreSQL required
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────
# SQLite (dev):
DATABASE_URL=sqlite:///./financial.db
# PostgreSQL (production) — uncomment and configure:
# DATABASE_URL=postgresql://user:password@localhost:5432/trad_account
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# ── Security (REQUIRED — generate real secrets for production) ──────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate-a-real-64-char-hex-string
# Encryption key for LLM API keys stored in DB.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Generate a real key for production. Do NOT leave empty in production.
ENCRYPTION_KEY=

# ── User Passwords (used by seed script) ─────────────────────────────
ADMIN_PASSWORD=change-me-admin
ACCOUNTANT_PASSWORD=change-me-accountant
AUDITOR_PASSWORD=change-me-auditor

# ── AI / LLM ────────────────────────────────────────────────────────
# Get your API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key

# ── Redis (optional, for rate limiting) ─────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── CORS ────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
